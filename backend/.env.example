# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────
# Local:   mongodb://localhost:27017/shopalpha
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/shopalpha
MONGO_URI=mongodb://localhost:27017/shopalpha

# ─── JWT ──────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
